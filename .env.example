# 通义千问 API Key
DASHSCOPE_API_KEY=sk-your-dashscope-api-key
LLM_MODEL=qwen-plus

# JWT（可与 langchain-learn 共用密钥）
JWT_SECRET=please-change-this-jwt-secret-key-at-least-32-chars
JWT_ACCESS_EXPIRATION_SECONDS=900
JWT_ACCESS_BLACKLIST_ENABLED=true

# MySQL（可与 Java / langchain-learn 共用 test1 库）
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=test1

# RAG 知识库与向量库
KNOWLEDGE_DIR=data/knowledge
RAG_CHROMA_PATH=data/chroma
RAG_RECALL_TOP_K=10
RAG_RERANK_TOP_N=5
RAG_RERANK_THRESHOLD=0.35
RAG_RRF_K=60
RAG_RERANK_MODEL=gte-rerank

# 测评报告导入
REPORT_CHUNK_SIZE=1200
REPORT_CHUNK_OVERLAP=250
REPORT_MAX_UPLOAD_MB=15
RAG_VECTOR_TOP_K=3
